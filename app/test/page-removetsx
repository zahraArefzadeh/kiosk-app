"use client";

import React, { useState, useRef, useMemo, useEffect } from "react";
import { useMockVoiceChat } from "@/hooks/useMockVoiceChat";
import { TranslationKey, translations } from "@/utils/translations";
import { 
  Settings, 
  Phone, 
  Monitor, 
  Zap, 
  RefreshCcw, 
  Database, 
  Image as ImageIcon, 
  DollarSign, 
  MessageSquare,
  AlertTriangle
} from "lucide-react";
// مسیر ایمپورت را بر اساس ساختار پروژه خود تنظیم کنید
import WidgetView from "@/components/WidgetView";

const LANGUAGES = [
  { code: "en", name: "English", countryCode: "US" as const },
  { code: "de", name: "Deutsch", countryCode: "DE" as const },
  { code: "fa", name: "فارسی", countryCode: "IR" as const },
];

export default function WidgetPlayground() {
  const mockChat = useMockVoiceChat();
  
  // Local View State
  const [isOpen, setIsOpen] = useState(true);
  const [showHistory, setShowHistory] = useState(false);
  const [inputValue, setInputValue] = useState("");
  const [selectedLanguage, setSelectedLanguage] = useState<TranslationKey>("en"); // Default to Persian for easier testing
  const [showLoading, setShowLoading] = useState(true);
  const [loadingStep, setLoadingStep] = useState(0);
  const [deviceSize, setDeviceSize] = useState<'mobile' | 'desktop'>('mobile');

  // Refs
  const inputRef = useRef<HTMLInputElement>(null);
  const messagesContainerRef = useRef<HTMLDivElement>(null);
  const carouselRef = useRef<HTMLDivElement>(null);
  const [currentProductIndex, setCurrentProductIndex] = useState(0);

  // Translations
  const t = useMemo(() => translations[selectedLanguage] || translations['en'], [selectedLanguage]);
  const loadingMessages = useMemo(() => [
      t.loading?.step1 || "Connecting...", 
      t.loading?.step2 || "Finding Agent...", 
      t.loading?.step3 || "Ready"
  ], [t]);

  // --- Handlers ---
  const handleLanguageChange = (code: string) => {
      setSelectedLanguage(code as TranslationKey);
      mockChat.sendLanguageChange(code);
  };
  
  const handleSend = () => {
      if(inputValue.trim()) {
          mockChat.sendTextMessage(inputValue);
          setInputValue("");
      }
  };

  // Loading Logic Simulation
  useEffect(() => {
    if(showLoading) {
        const interval = setInterval(() => setLoadingStep(p => (p < 2 ? p + 1 : 0)), 800);
        return () => clearInterval(interval);
    }
  }, [showLoading]);

  // Product Scroll Logic Mock
  const productWidth = 280; 
  const scrollToProduct = (index: number) => {
    setCurrentProductIndex(index);
    if(carouselRef.current) carouselRef.current.scrollTo({ left: index * productWidth, behavior: 'smooth' });
  };

  return (
    <div className="flex w-full h-screen bg-[#111] text-gray-200 overflow-hidden font-sans" dir="ltr">
      
      {/* ================= LEFT SIDEBAR: SCENARIOS ================= */}
      <div className="w-72 bg-[#161616] border-r border-gray-800 flex flex-col z-20 overflow-y-auto scrollbar-thin scrollbar-thumb-gray-700">
        
        {/* Header */}
        <div className="p-4 border-b border-gray-800 bg-[#161616] sticky top-0 z-10">
            <h2 className="text-xs font-bold text-gray-400 uppercase tracking-widest flex items-center gap-2">
                <Zap size={14} className="text-yellow-500"/> Testing Scenarios
            </h2>
        </div>
        
        <div className="p-4 space-y-6">
            
            {/* Standard Flows */}
            <div className="space-y-2">
                <h3 className="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">Standard Flows</h3>
                <ScenarioBtn 
                    icon={<Zap size={16} className="text-blue-400"/>}
                    label="Basic E-Commerce" 
                    desc="Single product with price"
                    onClick={() => {
                        setIsOpen(true); setShowLoading(false);
                        mockChat.controls.simulateScenario('ecommerce_simple');
                    }} 
                />
                 <ScenarioBtn 
                    icon={<Monitor size={16} className="text-purple-400"/>}
                    label="Video Call Mode" 
                    desc="Video enabled agent"
                    onClick={() => {
                         setIsOpen(true); setShowLoading(false);
                         mockChat.controls.simulateScenario('video_mode');
                    }} 
                />
            </div>

            {/* 🔥 Data Stress Tests */}
            <div className="space-y-2">
                <h3 className="text-[10px] font-bold text-blue-400/80 uppercase tracking-wider flex items-center gap-1 ml-1 mt-4">
                    <Database size={10}/> Data Stress Tests
                </h3>
                
                <ScenarioBtn 
                    icon={<ImageIcon size={16} className="text-pink-400"/>}
                    label="Multi-Image Product" 
                    desc="Tests gallery modal & badges"
                    onClick={() => {
                        setIsOpen(true); setShowLoading(false);
                        mockChat.controls.simulateScenario('product_multi_image');
                    }} 
                />

                <ScenarioBtn 
                    icon={<DollarSign size={16} className="text-green-400"/>}
                    label="Complex Pricing" 
                    desc="Null, String, Formatted prices"
                    onClick={() => {
                        setIsOpen(true); setShowLoading(false);
                        mockChat.controls.simulateScenario('product_complex_prices');
                    }} 
                />

                <ScenarioBtn 
                    icon={<MessageSquare size={16} className="text-orange-400"/>}
                    label="Quick Replies Stress" 
                    desc="Long text, Emoji, RTL"
                    onClick={() => {
                        setIsOpen(true); setShowLoading(false);
                        mockChat.controls.simulateScenario('quick_reply_stress');
                    }} 
                />
            </div>

             {/* Error States */}
             <div className="space-y-2">
                <h3 className="text-[10px] font-bold text-red-400/80 uppercase tracking-wider ml-1 mt-4">Edge Cases</h3>
                <ScenarioBtn 
                    icon={<AlertTriangle size={16} className="text-red-500"/>}
                    label="Connection Error" 
                    desc="Simulate disconnect state"
                    onClick={() => mockChat.controls.simulateScenario('error_state')} 
                    color="red"
                />
            </div>
        </div>

        <div className="mt-auto border-t border-gray-800 p-4 bg-[#161616] sticky bottom-0">
             <button onClick={() => {
                 mockChat.disconnectRoom();
                 setShowLoading(true);
                 mockChat.initializeConnection();
             }} className="flex items-center justify-center gap-2 text-xs font-medium text-blue-300 hover:text-white w-full p-2.5 rounded-lg bg-blue-900/20 hover:bg-blue-600 transition-all border border-blue-900/50 hover:border-blue-500">
                 <RefreshCcw size={14} /> Restart Connection
             </button>
        </div>
      </div>

      {/* ================= CENTER: DEVICE SIMULATOR ================= */}
      <div className="flex-1 relative bg-[#0a0a0a] flex flex-col items-center justify-center p-8 bg-grid-pattern">
        
        {/* Device Toggle */}
        <div className="absolute top-4 bg-[#1f1f1f] p-1 rounded-lg border border-gray-800 flex gap-1 z-30 shadow-xl">
            <button onClick={() => setDeviceSize('mobile')} className={`p-2 rounded-md transition-all ${deviceSize === 'mobile' ? 'bg-blue-600 text-white shadow-lg' : 'text-gray-400 hover:text-white hover:bg-white/10'}`}>
                <Phone size={18} />
            </button>
            <button onClick={() => setDeviceSize('desktop')} className={`p-2 rounded-md transition-all ${deviceSize === 'desktop' ? 'bg-blue-600 text-white shadow-lg' : 'text-gray-400 hover:text-white hover:bg-white/10'}`}>
                <Monitor size={18} />
            </button>
        </div>

        {/* THE DEVICE FRAME */}
        <div 
            className={`
                relative transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] shadow-2xl border-gray-800 bg-black
                ${deviceSize === 'mobile' 
                    ? 'w-[375px] h-[812px] rounded-[48px] border-[8px] border-[#2a2a2a] ring-1 ring-white/10' 
                    : 'w-full max-w-[1024px] h-[700px] rounded-xl border border-gray-700 ring-1 ring-white/10'
                }
            `}
        >
             {/* Notch for mobile */}
             {deviceSize === 'mobile' && (
                 <div className="absolute top-0 left-1/2 -translate-x-1/2 w-36 h-7 bg-[#2a2a2a] rounded-b-2xl z-[60] pointer-events-none border-b border-x border-black/50"></div>
             )}

            <div className="w-full h-full overflow-hidden relative rounded-[38px] bg-slate-900">
                 <WidgetView
                    // Basic Props
                    isOpen={isOpen}
                    onClose={() => setIsOpen(false)}
                    showHistory={showHistory}
                    setShowHistory={setShowHistory}
                    showLoading={showLoading}
                    loadingStep={loadingStep}
                    loadingMessages={loadingMessages}
                    
                    // Language
                    selectedLanguage={selectedLanguage}
                    onLanguageChange={handleLanguageChange}
                    t={t}
                    LANGUAGES={LANGUAGES}
                    
                    // Chat Data
                    messages={mockChat.messages}
                    inputValue={inputValue}
                    setInputValue={setInputValue}
                    onSend={handleSend}
                    isAgentTyping={mockChat.isAgentTyping}
                    
                    // Connection Status
                    isConnected={mockChat.isConnected}
                    isAgentConnected={mockChat.isAgentConnected}
                    
                    // Audio/Video Controls
                    isMicMuted={mockChat.isMicMuted}
                    onMicPress={mockChat.toggleMicrophone}
                    onMicRelease={mockChat.toggleMicrophone}
                    isAgentMuted={mockChat.isAgentMuted}
                    toggleAgentMute={mockChat.toggleAgentMute}
                    
                    isVideoModeEnabled={mockChat.isVideoModeEnabled}
                    isAgentVideoEnabled={mockChat.isAgentVideoEnabled}
                    agentVideoElement={null}
                    isAgentActive={mockChat.isAgentActive}

                    // Products Logic
                    products={mockChat.products}
                    currentProductIndex={currentProductIndex}
                    onClearProducts={() => mockChat.controls.setProducts([])}
                    carouselRef={carouselRef}
                    onPreviousProduct={() => scrollToProduct(Math.max(0, currentProductIndex - 1))}
                    onNextProduct={() => scrollToProduct(Math.min(mockChat.products.length - 1, currentProductIndex + 1))}
                    onProductClick={scrollToProduct}
                    onProductScroll={() => {}} 

                    // Quick Replies
                    quickReplies={mockChat.quickReplies}
                    onQuickReplySelect={(val) => mockChat.sendTextMessage(val)}

                    // Refs
                    messagesContainerRef={messagesContainerRef}
                    inputRef={inputRef}
                />
            </div>
        </div>
        
        <div className="mt-6 text-gray-600 text-[10px] font-mono tracking-wider uppercase">
            {deviceSize === 'mobile' ? 'Viewport: 375x812 (iPhone X/13)' : 'Viewport: Desktop Mock'}
        </div>
      </div>

      {/* ================= RIGHT SIDEBAR: CONTROLS ================= */}
      <div className="w-80 bg-[#161616] border-l border-gray-800 flex flex-col overflow-y-auto z-20">
        <div className="p-4 border-b border-gray-800 bg-[#161616] sticky top-0">
            <h2 className="font-bold text-gray-300 flex items-center gap-2 text-sm">
                <Settings size={16} /> Live Controls
            </h2>
        </div>

        <div className="p-4 space-y-8">
            <ControlSection title="System State">
                <Toggle label="Widget Open" value={isOpen} onChange={setIsOpen} />
                <Toggle label="Show Loading" value={showLoading} onChange={setShowLoading} />
                <Toggle label="Show History" value={showHistory} onChange={setShowHistory} />
            </ControlSection>

            <ControlSection title="Data Management">
                 <div className="grid grid-cols-2 gap-2">
                     <button 
                        onClick={() => mockChat.controls.setProducts([])}
                        className="p-2 text-[10px] font-medium bg-red-950/30 text-red-400 border border-red-900/50 rounded hover:bg-red-900/40 transition hover:border-red-700"
                     >
                        Clear Products
                     </button>
                     <button 
                        onClick={() => mockChat.controls.setQuickReplies([])}
                        className="p-2 text-[10px] font-medium bg-gray-800 text-gray-400 border border-gray-700 rounded hover:bg-gray-700 transition hover:text-gray-200"
                     >
                        Clear Replies
                     </button>
                 </div>
            </ControlSection>

            <ControlSection title="Agent Status">
                <Toggle label="Is Typing..." value={mockChat.isAgentTyping} onChange={mockChat.controls.setIsAgentTyping} />
                <Toggle label="Is Speaking (Wave)" value={mockChat.isAgentSpeaking} onChange={mockChat.controls.setIsAgentSpeaking} />
                <Toggle label="Video Mode" value={mockChat.isVideoModeEnabled} onChange={mockChat.controls.setIsVideoModeEnabled} />
            </ControlSection>

            <ControlSection title="Environment">
                <label className="text-[10px] text-gray-500 font-bold block mb-2 uppercase tracking-wide">Interface Language</label>
                <select 
                    className="w-full bg-[#222] border border-gray-700 rounded-lg p-2.5 text-sm text-gray-300 focus:outline-none focus:border-blue-500 transition-colors"
                    value={selectedLanguage}
                    onChange={(e) => handleLanguageChange(e.target.value)}
                >
                    {LANGUAGES.map(l => <option key={l.code} value={l.code}>{l.name}</option>)}
                </select>
            </ControlSection>
        </div>
      </div>

    </div>
  );
}

// --- UI Sub Components ---

function ControlSection({ title, children }: { title: string, children: React.ReactNode }) {
    return (
        <div className="space-y-3">
            <h3 className="text-[10px] font-bold text-gray-500 uppercase tracking-widest border-l-2 border-gray-700 pl-2">{title}</h3>
            <div className="space-y-2">
                {children}
            </div>
        </div>
    );
}

function Toggle({ label, value, onChange }: { label: string, value: boolean, onChange: (v: boolean) => void }) {
    return (
        <button 
            onClick={() => onChange(!value)}
            className={`w-full flex items-center justify-between p-2.5 rounded-lg border transition-all duration-200 group ${value ? 'bg-blue-900/20 border-blue-500/50' : 'bg-[#1f1f1f] border-gray-800 hover:border-gray-600'}`}
        >
            <span className={`text-xs font-medium ${value ? 'text-blue-200' : 'text-gray-400 group-hover:text-gray-300'}`}>{label}</span>
            <div className={`w-8 h-4 rounded-full relative transition-colors ${value ? 'bg-blue-500' : 'bg-gray-700'}`}>
                <div className={`absolute top-0.5 w-3 h-3 bg-white rounded-full shadow-sm transition-transform duration-200 ${value ? 'translate-x-4' : 'translate-x-0.5'}`} />
            </div>
        </button>
    );
}
function ScenarioBtn({ label, desc, onClick, color = "blue", icon }: { label: string, desc: string, onClick: () => void, color?: string, icon?: React.ReactNode }) {
    return (
        <button 
            onClick={onClick}
            className={`w-full text-left p-3 rounded-xl border border-gray-800/60 bg-[#1f1f1f] hover:bg-[#252525] hover:border-gray-600 transition-all group flex items-start gap-3 relative overflow-hidden`}
        >
            {/* Icon Wrapper */}
            <div className="mt-1 relative z-10 p-1.5 rounded-md bg-black/20 group-hover:bg-black/40 transition-colors">
                {icon}
            </div>
            
            {/* Text Content */}
            <div className="relative z-10 flex-1">
                <div className="text-xs font-semibold text-gray-300 group-hover:text-white transition-colors">{label}</div>
                {/* اینجا خطی بود که قطع شده بود */}
                <div className="text-[10px] text-gray-500 mt-0.5 group-hover:text-gray-400 transition-colors leading-snug">
                    {desc}
                </div>
            </div>

            {/* Subtle Hover Gradient Effect based on color prop */}
            <div className={`absolute inset-0 opacity-0 group-hover:opacity-5 transition-opacity duration-300 bg-${color}-500 pointer-events-none`} />
        </button>
    );
}
